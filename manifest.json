{
  "manifest_version": 3,
  "name": "Form AutoFill Saver",
  "version": "1.0",
  "description": "Save and auto-fill form data per URL/page. Useful for testing forms repeatedly.",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Form AutoFill Saver"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
